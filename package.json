{
  "name": "purple-cross-employee-dashboard",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "coverage": "turbo run coverage",
    "db:generate": "npm --workspace @purple-cross/db run generate",
    "db:migrate": "npm --workspace @purple-cross/db run migrate",
    "db:seed": "npm --workspace @purple-cross/db run seed",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "preview": "npm --workspace @purple-cross/web run preview",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "test:unit": "vitest run"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "turbo": "^2.6.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.7",
    "vue-tsc": "^3.3.7"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  }
}
