{
  "name": "shireburn-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "coverage": "turbo run coverage",
    "db:generate": "node --env-file-if-exists=.env node_modules/prisma/build/index.js generate --schema packages/db/prisma/schema.prisma",
    "db:migrate": "node --env-file-if-exists=.env node_modules/prisma/build/index.js migrate dev --schema packages/db/prisma/schema.prisma",
    "db:seed": "node --env-file-if-exists=.env node_modules/tsx/dist/cli.mjs packages/db/prisma/seed.ts",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "preview": "npm --workspace @shireburn-platform/employee-management run preview",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "test:unit": "vitest run",
    "storybook": "npm --workspace @shireburn-platform/employee-management run storybook",
    "storybook:build": "npm --workspace @shireburn-platform/employee-management run storybook:build"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.118",
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.56.1",
    "@storybook/addon-a11y": "^10.5.2",
    "@storybook/vue3-vite": "^10.5.2",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitest/coverage-v8": "^4.1.10",
    "happy-dom": "^20.10.6",
    "storybook": "^10.5.2",
    "turbo": "^2.6.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  }
}
