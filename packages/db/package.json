{
  "name": "@purple-cross/db",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "prisma generate --schema prisma/schema.prisma && tsc --noEmit",
    "generate": "prisma generate --schema prisma/schema.prisma",
    "migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts",
    "test": "vitest run src",
    "coverage": "vitest run src --coverage"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@purple-cross/shared": "0.1.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "prisma": "^6.19.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.7"
  }
}
